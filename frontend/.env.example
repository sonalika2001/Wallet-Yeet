# Copy this file to `.env.local` and fill in real values.
# WalletYeet runs on Sepolia (chainId 11155111). Without these keys,
# the frontend falls back to mock data so you can preview the UI freely.

# --- Server-only (NEVER prefix NEXT_PUBLIC_) ---
ANTHROPIC_API_KEY=
ALCHEMY_API_KEY=
KEEPERHUB_API_KEY=

# --- Public (safe to ship to the browser) ---
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/REPLACE_ME
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- Deployed contract addresses (fill after `forge script Deploy.s.sol`) ---
NEXT_PUBLIC_MIGRATION_VAULT_ADDRESS=
NEXT_PUBLIC_MIGRATION_LOG_ADDRESS=

# --- Demo wallets (only used by client UI for nice display) ---
NEXT_PUBLIC_DEMO_OLD_ADDRESS=
NEXT_PUBLIC_DEMO_NEW_ADDRESS=
NEXT_PUBLIC_DEMO_COLD_ADDRESS=

# --- Sponsor adapter feature flags (override defaults in lib/config.ts) ---
NEXT_PUBLIC_FEATURE_KEEPERHUB=true
NEXT_PUBLIC_FEATURE_UNISWAP=true
NEXT_PUBLIC_FEATURE_ENS=true
